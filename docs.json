{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Tuco AI",
  "colors": {
    "primary": "#FF3515",
    "light": "#FFF5F2",
    "dark": "#111827"
  },
  "favicon": "/images/tuco_v1_round.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/upload-leads",
              "features/check-availability",
              "features/send-messages"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/create",
              "api-reference/endpoint/get",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.tuco.ai",
          "icon": "browser"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@tuco.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://app.tuco.ai"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/tucoai",
      "github": "https://github.com/tuco-ai",
      "linkedin": "https://linkedin.com/company/tuco-ai"
    }
  }
}
